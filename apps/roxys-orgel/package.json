{
  "name": "roxys-orgel",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "preview": "$npm_execpath run build && vite preview",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:update": "$npm_execpath run build && npx wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "d1-migrate": "wrangler d1 migrations apply roxys-orgel --remote"
  },
  "dependencies": {
    "@chenglou/pretext": "^0.0.8",
    "@hono/trpc-server": "^0.3.3",
    "@react-spring/web": "^10.1.2",
    "@tanstack/react-query": "^5.80.7",
    "@tanstack/react-router": "^1.167.5",
    "@trpc/client": "^11.7.0",
    "@trpc/react-query": "^11.7.0",
    "@trpc/server": "^11.7.0",
    "clsx": "^2.1.1",
    "hono": "^4.12.8",
    "jotai": "^2.18.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "superjson": "^2.2.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/puppeteer": "^1.1.0",
    "@cloudflare/vite-plugin": "^1.45.1",
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/router-plugin": "^1.166.14",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^6.0.1",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.2",
    "vite-ssr-components": "^0.5.2"
  }
}
