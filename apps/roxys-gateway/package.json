{
  "name": "roxys-gateway",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "build": "vite build",
    "deploy": "$npm_execpath run build && wrangler deploy",
    "deploy:update": "$npm_execpath run build && npx wrangler versions upload",
    "cf-typegen": "wrangler types --env-interface GatewayBindings"
  },
  "dependencies": {
    "hono": "^4.12.8"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.45.1"
  }
}
